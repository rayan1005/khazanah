rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }
    
    function isUnder5MB() {
      return request.resource.size < 5 * 1024 * 1024;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Post images
    match /posts/{postId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated() && isImage() && isUnder5MB();
    }
    
    // User avatars
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) && isImage() && isUnder5MB();
    }
    
    // Brand images (admin only)
    match /brands/{brandId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && isImage() && isUnder5MB();
    }
    
    // Banner images (admin only)
    match /banners/{bannerId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && isImage() && isUnder5MB();
    }
    
    // Section images (admin only)
    match /sections/{sectionId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && isImage() && isUnder5MB();
    }
    
    // Category images (admin only)
    match /categories/{categoryId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && isImage() && isUnder5MB();
    }
  }
}
